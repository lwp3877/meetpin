# ============================================================
# 밋핀(MeetPin) 환경 변수 예시
# ============================================================
# 사용법:
#   cp .env.example .env.local
#   각 항목을 실제 값으로 교체하세요.
#
# 규칙:
#   - NEXT_PUBLIC_ 접두사: 브라우저에도 노출됨 (클라이언트 코드에서 사용 가능)
#   - 그 외: 서버 전용 (API route, 서버 컴포넌트에서만 사용)
#   - .env.local은 .gitignore에 포함되어 Git에 커밋되지 않음
# ============================================================

# ============================================================
# [필수] Supabase — 백엔드 서비스 (인증, DB, 스토리지)
# ============================================================
# https://supabase.com/dashboard → 프로젝트 → Settings → API

# 프로젝트 URL (브라우저 노출 가능)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anonymous Key (브라우저 노출 가능 — RLS 정책이 보안을 담당)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (서버 전용 — 절대 브라우저 노출 금지, RLS 우회)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# [필수] 카카오맵 API — 지도 서비스
# ============================================================
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# 등록된 도메인에서만 동작 (도메인 제한으로 보안 처리)
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=your_kakao_javascript_key

# ============================================================
# [필수] 앱 기본 URL — 리다이렉트, 이메일 링크 등에 사용
# ============================================================
# 개발: http://localhost:3001
# 프로덕션: https://your-domain.vercel.app 또는 커스텀 도메인
SITE_URL=http://localhost:3001

# ============================================================
# [필수 - 결제 기능 사용 시] Stripe — 결제 서비스
# ============================================================
# https://dashboard.stripe.com → Developers → API keys
# 개발: sk_test_..., 프로덕션: sk_live_...

# Secret Key (서버 전용 — 절대 브라우저 노출 금지)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Publishable Key (브라우저 노출 가능)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Webhook Secret (서버 전용 — stripe listen으로 발급 또는 대시보드에서 확인)
# 개발: stripe listen --forward-to localhost:3001/api/payments/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe 부스트 상품 Price ID (옵션 — 상품 생성 후 설정)
STRIPE_PRICE_1D_ID=price_1day_boost_id
STRIPE_PRICE_3D_ID=price_3day_boost_id
STRIPE_PRICE_7D_ID=price_7day_boost_id

# ============================================================
# [필수 - rate limiting] Upstash Redis — HTTP REST 방식
# ============================================================
# https://console.upstash.com → Redis 데이터베이스 생성 → REST API 탭
# 무료 플랜 사용 가능. rate limiting에만 사용됨.
UPSTASH_REDIS_REST_URL=https://your-redis-rest-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token

# ============================================================
# [선택] Redis 캐싱 — TCP 방식 (ioredis)
# ============================================================
# 이 값이 없으면 캐싱이 비활성화되고 DB에서 직접 조회합니다.
# 성능은 약간 낮아지지만 기능에는 문제 없습니다.
# 설정하려면: Upstash 대시보드 → Details → Endpoint (redis://... 형식)
# 주의: UPSTASH_REDIS_REST_URL(HTTP)과 다른 URL입니다.
# REDIS_URL=rediss://your-upstash-tcp-url:6380

# ============================================================
# [선택] Sentry — 오류 추적
# ============================================================
# https://sentry.io → 프로젝트 생성 → DSN 확인
# 없으면 오류 추적 기능 비활성화 (Vercel 로그로 대체)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project-id

# ============================================================
# [선택] 봇 시스템 — 자동 방 생성 봇
# ============================================================
BOT_DEFAULT_PASSWORD=your_secure_bot_password_here
BOT_ADMIN_KEY=your_bot_admin_key_here

# ============================================================
# Feature Flags — 기능 ON/OFF 토글
# ============================================================
# 카카오 OAuth 소셜 로그인 (기본: 비활성화)
NEXT_PUBLIC_ENABLE_KAKAO_OAUTH=false

# 실시간 알림 (기본: 활성화)
NEXT_PUBLIC_ENABLE_REALTIME_NOTIFICATIONS=true

# 사용자 신고/차단 (기본: 활성화)
NEXT_PUBLIC_ENABLE_USER_REPORTING=true

# 위치 기반 검색 (기본: 활성화)
NEXT_PUBLIC_ENABLE_LOCATION_SEARCH=true

# 파일 업로드 아바타 (기본: 활성화)
NEXT_PUBLIC_ENABLE_FILE_UPLOAD=true

# 관리자 패널 (기본: 활성화)
NEXT_PUBLIC_ENABLE_ADMIN_PANEL=true

# 분석 도구 (기본: 비활성화)
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ============================================================
# 개발 전용 — Mock 모드
# ============================================================
# true: Supabase 없이 목 데이터로 동작 (로컬 개발 전용)
# 배포 환경에서는 반드시 false 또는 미설정
NEXT_PUBLIC_USE_MOCK_DATA=false
